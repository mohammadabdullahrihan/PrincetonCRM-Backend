doctype html
html
  head
    link(rel="shortcut icon" type="image/png" href="/images/icons/favicon.png")
    meta(name="viewport" content="width=device-width, initial-scale=1")
    style.
      body {
        width: 100%;
        margin: 0;
        padding: 0;
        background: #ffffff;
        font-family: sans-serif;
        font-size: 12px;
        color: #222;
      }
      *, *:before, *:after {
        box-sizing: border-box;
      }
      .receipt {
        padding: 14px 18px;
      }
      .receipt + .receipt {
        border-top: 2px dashed #999;
      }
      .cut-label {
        text-align: center;
        font-size: 9px;
        letter-spacing: 2px;
        color: #999;
        margin: 2px 0 8px;
      }
      .header {
        display: table;
        width: 100%;
        margin-bottom: 8px;
      }
      .header .logo-cell {
        display: table-cell;
        width: 70px;
        vertical-align: top;
      }
      .header .logo-cell img {
        width: 60px;
      }
      .header .company-cell {
        display: table-cell;
        vertical-align: top;
      }
      .company-name {
        font-size: 15px;
        font-weight: 700;
        color: #52008c;
        margin: 0 0 2px;
      }
      .company-meta {
        font-size: 10px;
        color: #555;
        margin: 0;
        line-height: 1.5;
      }
      .header .copy-cell {
        display: table-cell;
        width: 110px;
        vertical-align: top;
        text-align: right;
      }
      .copy-badge {
        display: inline-block;
        border: 1px solid #52008c;
        color: #52008c;
        font-size: 10px;
        font-weight: 700;
        padding: 2px 8px;
        border-radius: 3px;
      }
      .title-row {
        display: table;
        width: 100%;
        border-top: 1px solid #52008c;
        border-bottom: 1px solid #52008c;
        padding: 4px 0;
        margin-bottom: 8px;
      }
      .title-row .title-cell {
        display: table-cell;
        font-size: 15px;
        font-weight: 700;
        letter-spacing: 1px;
      }
      .title-row .meta-cell {
        display: table-cell;
        text-align: right;
        font-size: 11px;
      }
      .field-row {
        display: table;
        width: 100%;
        margin-bottom: 5px;
      }
      .field-row .field {
        display: table-cell;
        width: 50%;
        padding-right: 10px;
        vertical-align: bottom;
      }
      .field-label {
        color: #555;
        font-size: 10px;
      }
      .field-value {
        border-bottom: 1px solid #ccc;
        padding: 1px 0 2px;
        min-height: 14px;
        font-size: 12px;
        font-weight: 600;
      }
      .amount-words .field-value {
        min-height: 14px;
      }
      .signatures {
        display: table;
        width: 100%;
        margin-top: 26px;
      }
      .signatures .sig-cell {
        display: table-cell;
        width: 33.33%;
        text-align: center;
        font-size: 10px;
        color: #555;
      }
      .sig-line {
        border-top: 1px solid #666;
        margin: 22px 10px 4px;
      }
    body
      each copyLabel in ['OFFICE COPY', 'CLIENT COPY']
        .receipt
          .cut-label ✂ - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
          .header
            .logo-cell
              if logoDataUri
                img(src=logoDataUri)
            .company-cell
              p.company-name #{settings.company_name}
              p.company-meta #{settings.company_address}
              p.company-meta Call: #{settings.company_phone} &nbsp; Email: #{settings.company_email}
            .copy-cell
              span.copy-badge= copyLabel

          .title-row
            .title-cell MONEY RECEIPT
            .meta-cell
              div SL NO: #{settings.payment_prefix || ''}#{model.number}
              div Date: #{moment(model.date).format(dateFormat)}

          .field-row
            .field
              .field-label Received With Thanks From
              .field-value= model.client ? model.client.name : ''
            .field
              .field-label Location
              .field-value= model.location || ''

          .field-row
            .field
              .field-label Project Name
              .field-value= model.projectName || ''
            .field
              .field-label Payment Purpose
              .field-value= model.paymentPurpose || ''

          .field-row
            .field
              .field-label Payment Method
              .field-value= model.paymentMode ? model.paymentMode.name : ''
            .field
              .field-label Cash / Cheque / P.O No
              .field-value= model.ref || ''

          .field-row
            .field
              .field-label Amount Paid
              .field-value= moneyFormatter({ amount: model.amount })
            .field.amount-words
              .field-label Amount in Words
              .field-value= numberToWords(model.amount) + ' ' + (settings.currency_name || '') + ' Only'

          .signatures
            .sig-cell
              .sig-line
              | Deposited By
              br
              | (Client or Representative)
            .sig-cell
              .sig-line
              | Received By
            .sig-cell
              .sig-line
              | Authorized By
