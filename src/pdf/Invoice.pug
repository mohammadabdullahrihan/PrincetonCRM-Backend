doctype html
html
  head
    link(rel="shortcut icon" type="image/png" href="/images/icons/favicon.png")
    meta(name="viewport" content="width=device-width, initial-scale=1")
    style.
      @font-face {
        font-family: 'Poppins';
        font-weight: 400;
        src: url(#{poppinsFonts[400]}) format('woff');
      }
      @font-face {
        font-family: 'Poppins';
        font-weight: 600;
        src: url(#{poppinsFonts[600]}) format('woff');
      }
      @font-face {
        font-family: 'Poppins';
        font-weight: 700;
        src: url(#{poppinsFonts[700]}) format('woff');
      }
      @font-face {
        font-family: 'Poppins';
        font-weight: 800;
        src: url(#{poppinsFonts[800]}) format('woff');
      }
      body {
        width: 100%;
        margin: 0;
        padding: 0;
        background: #ffffff;
        font-family: 'Poppins', sans-serif;
        font-size: 16px;
        color: #222;
      }
      *, *:before, *:after {
        box-sizing: border-box;
      }
      p {
        margin: 0;
      }
      /* ---- Page / header artwork ----
         The header (logo, company name/address/phone, "INVOICE" title, decorative
         shape) is baked into a designed PNG (src/pdf/assets/invoice-header-bg.png)
         rather than drawn with CSS, so it renders identically regardless of the PDF
         engine. background-size is WIDTH-only ("100% auto") rather than "cover" —
         the renderer's actual page pixel width can't be assumed (72dpi vs 96dpi
         conventions differ across PDF engines), so scaling strictly by width and
         never forcing a fixed page height avoids picking the wrong cover-axis
         (which crops the sides) or overflowing onto a spurious blank second page.
         The header-spacer's padding-top is a percentage of the PAGE WIDTH (CSS
         resolves percentage padding against the containing block's width, even for
         padding-top) which is exactly how background-size:100%-width scales this
         image, so the reserved space always tracks the artwork's header height.
         .page's min-height (1120px) matches Puppeteer/Chromium's standard 96dpi A4
         page (794x1123px, set as the viewport in pdfController) with a small
         safety buffer — this is what lets .signatures (position:absolute,
         bottom-anchored below) sit at the true bottom edge of the page. (The old
         810px value was specific to html-pdf/PhantomJS's 72dpi quirk from before
         the Puppeteer migration — don't reuse it if this ever changes engines
         again; re-derive from whatever that engine's actual page pixel size is.) */
      .page {
        position: relative;
        width: 100%;
        min-height: 1120px;
        background-image: url(#{invoiceHeaderBg});
        background-size: 100% auto;
        background-position: top center;
        background-repeat: no-repeat;
      }
      .header-spacer {
        position: relative;
        width: 100%;
        padding-top: 44%;
      }
      /* ---- Body ---- */
      .body-content {
        padding: 3px 72px 11px;
      }
      /* Dotted fill-in-the-blank field style, matching the money-receipt reference:
         a label, the value sitting on the line, and a dotted rule under the row.
         A small gold tick before each label ties it back to the brand accent. */
      .field-row {
        display: table;
        width: 100%;
        margin-bottom: 18px;
      }
      .field-row .field-col {
        display: table-cell;
        width: 50%;
        vertical-align: bottom;
        padding-right: 12px;
      }
      .field {
        border-bottom: 2px dotted #9a9a9a;
        padding-bottom: 8px;
      }
      .field-label {
        font-weight: 600;
        color: #14161c;
      }
      .field-value {
        color: #333;
        margin-left: 4px;
      }
      .field-sub {
        font-size: 15px;
        color: #666;
        margin: 8px 0 0;
        line-height: 1.6;
      }
      .field-boxed {
        border: 2px solid #14161c;
        border-radius: 5px;
        padding: 10px 20px;
        margin-bottom: 22px;
      }
      .field-boxed .field-label {
        font-size: 18px;
      }
      .field-boxed .field-value {
        font-size: 21px;
        font-weight: 700;
        color: #14161c;
      }
      /* ---- Notes ---- */
      .notes {
        margin-top: 0;
        margin-bottom: 8px;
      }
      .notes-label {
        font-weight: 600;
        color: #14161c;
        margin: 0 0 11px;
      }
      .notes-value {
        color: #444;
        line-height: 1.45;
        white-space: pre-wrap;
      }
      /* ---- Signatures ----
         Pinned to the true bottom of the page (see .page comment above) rather than
         following the document flow, so it always sits at the bottom of the sheet
         regardless of how short the content above it is. */
      .signatures {
        position: absolute;
        left: 72px;
        right: 72px;
        bottom: 32px;
        display: table;
        width: auto;
        table-layout: fixed;
      }
      .signatures .sig-cell {
        display: table-cell;
        width: 33.33%;
        text-align: center;
        font-size: 16px;
        color: #555;
      }
      .sig-line {
        border-top: 2px dotted #9a9a9a;
        margin: 0 26px 13px;
      }
      .sig-role {
        font-weight: 700;
        color: #14161c;
      }
      /* ---- Verification badge ----
         Small QR + caption, positioned as a child of .header-spacer with a
         NEGATIVE bottom offset — .header-spacer's own height is set by its
         width-based padding-top (see header comment above), so anchoring to ITS
         bottom edge (rather than a guessed top/height on .page) keeps the badge
         locked to the true seam between the header artwork and the white body,
         regardless of actual rendered page width. bottom:-64px places the badge
         just clear of the dark header, in the white area right beside the
         SL No/Date row, so it reads as a top-right corner badge, not something
         buried near the signatures. Costs zero document-flow height either way. */
      .verify-badge {
        position: absolute;
        right: 72px;
        bottom: -93px;
        width: 77px;
        text-align: center;
      }
      .verify-badge img {
        width: 66px;
        height: 66px;
        display: block;
        margin: 0 auto;
      }
      .verify-badge p {
        font-size: 9px;
        color: #888;
        line-height: 1.3;
        margin-top: 4px;
        word-break: break-all;
      }
  body
    .page
      .header-spacer
        if verifyQrDataUri
          .verify-badge
            img(src=verifyQrDataUri)
            p Scan to verify
      .body-content
        .field-row
          .field-col
            .field
              span.field-label SL No :
              span.field-value= model.number
          .field-col(style="padding-right:100px;")
            .field
              span.field-label Date :
              span.field-value= moment(model.date).format(dateFormat)

        .field-row
          .field-col(style="width:100%; padding-right:100px;")
            .field
              span.field-label Invoice No :
              span.field-value= (settings.invoice_prefix || '') + model.number + '/' + model.year

        .field-row
          .field-col(style="width:100%; padding-right:0;")
            .field
              span.field-label Payable To :
              span.field-value= model.client ? model.client.name : ''
            if model.client && (model.client.address || model.client.phone)
              p.field-sub
                if model.client.address
                  | #{model.client.address}
                if model.client.address && model.client.phone
                  |  &middot;&nbsp;
                if model.client.phone
                  | #{model.client.phone}

        .field-row
          .field-col
            .field
              span.field-label Location :
              span.field-value= model.location || '-'
          .field-col
            .field
              span.field-label Project Name :
              span.field-value= model.projectName || '-'

        .field-row
          .field-col(style="width:100%; padding-right:0;")
            .field
              span.field-label Payment Purpose :
              span.field-value= model.paymentPurpose || '-'

        .field-row
          .field-col(style="width:100%; padding-right:0;")
            .field
              span.field-label Payment Method :
              span.field-value= model.paymentMethod || '-'

        .field-boxed
          span.field-label Amount Paid :
          span.field-value= Number(model.total || 0).toLocaleString('en-US', { maximumFractionDigits: 0 }) + ' TK'

        .field-row
          .field-col(style="width:100%; padding-right:0;")
            .field
              span.field-label Amount in Words :
              span.field-value= numberToWords(model.total) + ' Taka Only'

        if model.notes
          .notes
            p.notes-label Notes
            p.notes-value= model.notes

      .signatures
        .sig-cell
          .sig-line
          p.sig-role Deposited By
          | (Client or Representative)
        .sig-cell
          .sig-line
          p.sig-role Received By
        .sig-cell
          .sig-line
          p.sig-role Authorized By
